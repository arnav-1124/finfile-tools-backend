# Supabase configuration
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=mykey
SUPABASE_STORAGE_BUCKET=finfile-tools-temp

# Python document-engine
DOCUMENT_ENGINE_CWD=../document-engine
DOCUMENT_ENGINE_PYTHON_PATH=../document-engine/.venv/Scripts/python.exe
DOCUMENT_ENGINE_TIMEOUT_MS=30000

# Port for the backend server
PORT=5000